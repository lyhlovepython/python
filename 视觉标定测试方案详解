### 7.2 OpenCV 标定代码框架

```python
import cv2
import numpy as np
import glob

# 1. 准备靶标参数
pattern_size = (9, 6)   # 内角点数
square_size = 25.0       # 方格边长 (mm)

objp = np.zeros((pattern_size[0]*pattern_size[1], 3), np.float32)
objp[:, :2] = np.mgrid[0:pattern_size[0], 0:pattern_size[1]].T.reshape(-1, 2)
objp *= square_size

obj_points = []  # 三维点
img_points = []  # 二维点

# 2. 检测角点
images = glob.glob('calibration_images/*.jpg')
for fname in images:
    img = cv2.imread(fname)
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    ret, corners = cv2.findChessboardCorners(gray, pattern_size, None)
    if ret:
        corners2 = cv2.cornerSubPix(gray, corners, (11, 11), (-1, -1),
            (cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 30, 0.001))
        obj_points.append(objp)
        img_points.append(corners2)

# 3. 标定
ret, K, dist, rvecs, tvecs = cv2.calibrateCamera(
    obj_points, img_points, gray.shape[::-1], None, None)

# 4. 评估重投影误差
total_error = 0
for i in range(len(obj_points)):
    proj, _ = cv2.projectPoints(obj_points[i], rvecs[i], tvecs[i], K, dist)
    error = cv2.norm(img_points[i], proj, cv2.NORM_L2) / len(proj)
    total_error += error
print(f"Mean reprojection error: {total_error/len(obj_points):.4f} px")
```

### 7.3 Kalibr 标定流程

```bash
# 1. 标定相机内参
kalibr_calibrate_cameras \
  --bag /path/to/calib.bag \
  --topics /cam0/image_raw \
  --models pinhole-radtan \
  --target /path/to/april_6x6.yaml

# 2. 标定相机-IMU
kalibr_calibrate_imu_camera \
  --bag /path/to/calib.bag \
  --cam /path/to/camchain.yaml \
  --imu /path/to/imu.yaml \
  --target /path/to/april_6x6.yaml
```

**Kalibr 支持的相机模型：**

| 投影模型 | 畸变模型 | 适用 |
|----------|----------|------|
| pinhole | radtan (径向+切向) | 普通相机 |
| pinhole | equidist | 中等广角 |
| omni | radtan | 鱼眼/全向 |
| ds (Double Sphere) | none | 超广角/鱼眼 |
| eucm (Extended UCM) | none | 超广角/鱼眼 |

